{
  "name": "@lvce-editor/test-with-playwright-worker",
  "version": "0.0.0-dev",
  "description": "Worker package for test-with-playwright",
  "repository": {
    "type": "git",
    "url": "git@github.com:lvce-editor/test-with-playwright.git",
    "directory": "packages/test-with-playwright-worker"
  },
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "src/workerMain.ts",
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ../../node_modules/jest/bin/jest.js --detectOpenHandles --forceExit --watch"
  },
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/test/**"
    ],
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "dependencies": {
    "@lvce-editor/assert": "^1.7.0",
    "@lvce-editor/rpc": "^6.8.0",
    "@lvce-editor/rpc-registry": "^9.34.0",
    "@lvce-editor/verror": "^1.7.0",
    "@playwright/test": "1.61.1",
    "dom-to-svg": "^0.12.2",
    "get-port": "^7.2.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "v8-to-istanbul": "^9.3.0"
  },
  "devDependencies": {
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4"
  },
  "engines": {
    "node": ">=24"
  }
}
